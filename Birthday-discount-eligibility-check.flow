2732ad4a0a7b0b084cea8905740c053fbb81cfdb6f767fda8a57b3ffc0c83bb6:{"__metadata":{"version":0.1},"root":{"steps":[{"step_id":"56c2edce-890f-48db-b5d2-dab7d51033bc","step_position":[0,0],"config_field_values":[{"config_field_id":"recurrence","value":"[\"DTSTART;TZID=Europe/Istanbul:20260515T005900\\nRRULE:FREQ=HOURLY;INTERVAL=4;WKST=MO\"]"}],"task_id":"shopify::flow::scheduled_time","task_version":"0.1","task_type":"TRIGGER","description":null,"note":null,"name":null},{"step_id":"596ac160-9e49-46f6-be22-ae0aca7a0e15","step_position":[0,220],"config_field_values":[{"config_field_id":"sort_by","value":"{\"sortKey\":\"CREATED_AT\",\"order\":\"ASCENDING\"}"},{"config_field_id":"max_root_records","value":"100"},{"config_field_id":"query","value":""}],"task_id":"shopify::flow::fetch::customers","task_version":"v1","task_type":"ACTION","description":null,"note":null,"name":"Get customer data"},{"step_id":"937076b8-88f1-487c-a121-014ba5ca875c","step_position":[0,380],"config_field_values":[{"config_field_id":"input","value":"query {\n  scheduledAt\n  getCustomerData {\n    id\n    firstName\n    email\n    birthdayOptIn {\n      value\n    }\n    birthdayDate {\n      value\n    }\n    lastBirthdayDiscountYear {\n      value\n    }\n  }\n}\n"},{"config_field_id":"script","value":"export default function main(input) {\n  const today = new Date(input.scheduledAt);\n  const todayMonth = today.getUTCMonth();\n  const todayDate = today.getUTCDate();\n  const currentYear = today.getUTCFullYear();\n\n  const eligibleCustomers = input.getCustomerData.filter((customer) => {\n    const birthdayOptIn = customer.birthdayOptIn?.value === true;\n    const birthdayDate = customer.birthdayDate?.value;\n    const lastDiscountYear = customer.lastBirthdayDiscountYear?.value;\n\n    if (!birthdayOptIn || !birthdayDate) return false;\n\n    const birthday = new Date(birthdayDate);\n    const isBirthdayToday = birthday.getUTCMonth() === todayMonth && birthday.getUTCDate() === todayDate;\n    const notProcessedThisYear = !lastDiscountYear || parseInt(lastDiscountYear) !== currentYear;\n\n    return isBirthdayToday && notProcessedThisYear;\n  }).map((c) => ({ id: c.id, firstName: c.firstName || 'Customer' }));\n\n  return {\n    eligibleCustomers,\n    currentYear: currentYear.toString(),\n  };\n}\n"},{"config_field_id":"output_schema","value":"type EligibleCustomer {\n  id: ID!\n  firstName: String!\n}\ntype Output {\n  eligibleCustomers: [EligibleCustomer!]!\n  currentYear: String!\n}\n"}],"task_id":"shopify::flow::run_code","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":"Run code"},{"step_id":"9721c3db-f5f7-46e8-ae47-daf2aff3028b","step_position":[0,480],"config_field_values":[{"config_field_id":"listpath","value":"runCode.eligibleCustomers"}],"task_id":"shopify::flow::foreach","task_version":"0.1","task_type":"FOREACH","description":null,"note":null,"name":null},{"step_id":"65a62b28-c940-4a94-bfdc-1ae74c59a830","step_position":[0,640],"config_field_values":[{"config_field_id":"customer_id","value":"{\"value\":\"{{ eligibleCustomersForeachitem.id }}\",\"default_value\":\"\"}"},{"config_field_id":"metafield","value":"{\"namespace\": \"app--356472127489\", \"key\": \"last_birthday_discount_year\", \"type\": \"number_integer\"}"},{"config_field_id":"value","value":"{{ runCode.currentYear }}"}],"task_id":"shopify::admin::add_customer_metafield","task_version":"1.0","task_type":"ACTION","description":null,"note":null,"name":null},{"step_id":"02f52516-9f68-43c9-98bc-9197774938dc","step_position":[0,820],"config_field_values":[{"config_field_id":"api_call","value":"{\"name\":\"discountCodeBasicCreate\",\"blob\":\"{\\n  \\\"basicCodeDiscount\\\": {\\n    \\\"code\\\": \\\"BIRTHDAY{{ eligibleCustomersForeachitem.firstName | upcase }}{{ runCode.currentYear }}\\\",\\n    \\\"title\\\": \\\"Birthday Discount - {{ eligibleCustomersForeachitem.firstName }}\\\",\\n    \\\"startsAt\\\": \\\"{{ scheduledAt }}\\\",\\n    \\\"endsAt\\\": \\\"{{ scheduledAt | date_plus: '1 year' }}\\\",\\n    \\\"appliesOncePerCustomer\\\": true,\\n    \\\"usageLimit\\\": 1,\\n    \\\"customerSelection\\\": {\\n      \\\"customers\\\": {\\n        \\\"add\\\": [\\n          \\\"{{ eligibleCustomersForeachitem.id }}\\\"\\n        ]\\n      }\\n    },\\n    \\\"customerGets\\\": {\\n      \\\"value\\\": {\\n        \\\"percentage\\\": 0.20\\n      },\\n      \\\"items\\\": {\\n        \\\"all\\\": true\\n      }\\n    }\\n  }\\n}\\n\"}"}],"task_id":"shopify::admin::admin_api_operation","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":"Send Admin API request"}],"links":[{"from_step_id":"56c2edce-890f-48db-b5d2-dab7d51033bc","from_port_id":"output","to_step_id":"596ac160-9e49-46f6-be22-ae0aca7a0e15","to_port_id":"input"},{"from_step_id":"596ac160-9e49-46f6-be22-ae0aca7a0e15","from_port_id":"output","to_step_id":"937076b8-88f1-487c-a121-014ba5ca875c","to_port_id":"input"},{"from_step_id":"937076b8-88f1-487c-a121-014ba5ca875c","from_port_id":"output","to_step_id":"9721c3db-f5f7-46e8-ae47-daf2aff3028b","to_port_id":"input"},{"from_step_id":"9721c3db-f5f7-46e8-ae47-daf2aff3028b","from_port_id":"loop_body","to_step_id":"65a62b28-c940-4a94-bfdc-1ae74c59a830","to_port_id":"input"},{"from_step_id":"65a62b28-c940-4a94-bfdc-1ae74c59a830","from_port_id":"output","to_step_id":"02f52516-9f68-43c9-98bc-9197774938dc","to_port_id":"input"}],"patched_fields":[{"id":"da77d5aa-3157-4fd3-92c9-7f87a5f3cfc3","handle":"birthdayDate","field":"metafield","patched_type":"Customer","arguments":"{\"key\":\"birthday_date\",\"namespace\":\"app--356472127489\"}","merchant_configured":true},{"id":"d5ae6f64-521b-4e12-9ec5-72f43045d85e","handle":"birthdayOptIn","field":"metafield","patched_type":"Customer","arguments":"{\"key\":\"birthday_opt_in\",\"namespace\":\"app--356472127489\"}","merchant_configured":true},{"id":"c125bee8-aad2-4c17-abfe-b0532cfdcef9","handle":"lastBirthdayDiscountYear","field":"metafield","patched_type":"Customer","arguments":"{\"key\":\"last_birthday_discount_year\",\"namespace\":\"app--356472127489\"}","merchant_configured":true}],"variables":[],"note":null,"vertical_layout_enabled":true,"workflow_name":"Birthday discount eligibility check"}}